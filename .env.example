# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Pexels (Pixel) API Configuration
PEXELS_API_KEY=your_pexels_api_key_here

# SMTP Email System Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_smtp_sender_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
RECIPIENT_EMAIL=your_recipient_email@gmail.com

# Blog Settings
BLOG_LENGTH_MIN=1500
BLOG_LENGTH_MAX=3000
CATEGORY_SELECTION_METHOD=sequential  # Options: sequential, random
